{
  "name": "tv",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "dependencies": {
    "@crateforge/core": "workspace:*",
    "@expo/vector-icons": "^15.1.1",
    "@tanstack/react-query": "^5.101.0",
    "expo": "~56.0.12",
    "expo-audio": "~56.0.12",
    "expo-build-properties": "~56.0.19",
    "expo-constants": "~56.0.18",
    "expo-crateforge-mdns": "workspace:*",
    "expo-device": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-image": "~56.0.11",
    "expo-router": "~56.2.11",
    "expo-secure-store": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.19",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-worklets": "0.8.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/react-native": "^14.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^26.0.0",
    "@types/react": "~19.2.2",
    "eas-cli": "^20.3.0",
    "jest-expo": "~56.0.5",
    "react-test-renderer": "19.2.3",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "build:android": "eas build --platform android --profile preview",
    "ota:preview": "eas update --branch preview"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ],
    "moduleNameMapper": {
      "^@crateforge/core$": "<rootDir>/../../packages/core/src/index.ts",
      "^@crateforge/core/(.*)$": "<rootDir>/../../packages/core/src/$1"
    }
  },
  "private": true
}
